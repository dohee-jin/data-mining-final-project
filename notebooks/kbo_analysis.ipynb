      "source": [
        "# ьїђ ВЮ┤ВаЂВю╝вАю ВЮИьЋю Ж│евЊаЖИђвЪгвИї вЮ╝в▓е ВЃЮВё▒ ВІцьїе Ж▒┤ ьЎЋВЮИ\n",
        "# Ж│евЊаЖИђвЪгвИї ВѕўВЃЂВъљ ьїђвфЁ в│┤ВаЋ\n",
        "# ЖИ░Вцђ: ВІюВЃЂВІЮ вІ╣ВІю ВєїВєЇВЮ┤ ВЋёвІѕвЮ╝ ьЋ┤вІ╣ ВІюВдї ВаЋЖиюВІюВдї ЖИ░вАЮ вЇ░ВЮ┤ьё░ВЮў Team Ж░њ\n",
        "\n",
        "team_corrections = {\n",
        "    (2017, \"Ж░Ћв»╝ьўИ\"): \"вА»вЇ░\",\n",
        "    (2016, \"ВхюьўЋВџ░\"): \"Вѓ╝Вё▒\",\n",
        "    (2022, \"ВќЉВЮўВДђ\"): \"NC\",\n",
        "    (2025, \"ВхюьўЋВџ░\"): \"KIA\"\n",
        "}\n",
        "\n",
        "for (year, name), team in team_corrections.items():\n",
        "    golden.loc[\n",
        "        (golden[\"Year\"] == year) & (golden[\"Name\"] == name),\n",
        "        \"Team\"\n",
        "    ] = team\n",
        "\n",
        "# 2018 ВЮ┤ВаЋьЏё ВёаВѕўВЮў Name, Team вХёвдг ВЋѕвљўвіћ вгИВаю ьЋ┤Ж▓░\n",
        "golden.loc[\n",
        "    (golden[\"Year\"] == 2018) &\n",
        "    (golden[\"Team\"].str.contains(\"ВЮ┤ВаЋьЏё\", na=False)),\n",
        "    [\"Name\", \"Team\"]\n",
        "] = [\"ВЮ┤ВаЋьЏё\", \"вёЦВё╝\"]\n"
      ],
