        "    ]),\n",
        "    \"Decision Tree\" : Pipeline([\n",
        "        (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
        "        (\"model\", DecisionTreeClassifier (\n",
        "            max_depth = 4,\n",
        "            random_state = 42,\n",
        "            class_weight = \"balanced\"\n",
        "        ))\n",
