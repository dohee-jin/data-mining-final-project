      "source": [
        "import numpy as np\n",
        "\n",
        "# ьЃђВъљ вфевЇИ ьЋЎВіх\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    x_hitter,\n",
        "    y_hitter,\n",
        "    test_size = 0.2,\n",
        "    random_state = 42,\n",
        "    stratify = y_hitter\n",
        ")\n",
        "\n",
        "hitter_models = {\n",
        "    \"Logistic Regression\": Pipeline([\n",
